{
  "name": "live2d-cyrene",
  "version": "0.1.0",
  "description": "Live2D desktop pet — Cyrene",
  "main": "dist/main/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dev": "npm run build:main && npm run build:preload && concurrently \"vite\" \"cross-env VITE_DEV=1 electron .\"",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:sim": "tsc -p tsconfig.sim.json",
    "sim": "tsc -p tsconfig.sim.json && node dist/sim/main/sim/dmae-sim.js",
    "sim:coffee": "tsc -p tsconfig.sim.json && node dist/sim/main/sim/dmae-sim.js --scenario=coffee",
    "sim:mix": "tsc -p tsconfig.sim.json && node dist/sim/main/sim/dmae-sim.js --scenario=mix",
    "sim:rescue": "tsc -p tsconfig.sim.json && node dist/sim/main/sim/dmae-sim.js --scenario=rescue",
    "sim:sweep": "tsc -p tsconfig.sim.json && node dist/sim/main/sim/dmae-sim.js --scenario=mix --rewardGain=3,5,7,10"
  },
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qr-image": "^3.2.11",
    "@types/turndown": "^5.0.6",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.57",
    "@ag-ui/core": "^0.0.57",
    "@lancedb/lancedb": "^0.30.0",
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@node-rs/jieba": "^2.0.1",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@types/ws": "^8.18.1",
    "@xenova/transformers": "^2.17.2",
    "chart.js": "^4.5.1",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^5.0.0",
    "llamaindex": "^0.12.1",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "pixi-live2d-display": "0.5.0-beta",
    "pixi.js": "^7.3.0",
    "playwright": "^1.60.0",
    "qr-image": "^3.2.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.1",
    "turndown": "^7.2.4",
    "wink-bm25-text-search": "^3.1.2",
    "ws": "^8.21.0"
  },
  "allowScripts": {
    "protobufjs@7.6.4": true,
    "protobufjs@6.11.6": true,
    "electron@43.1.0": true,
    "esbuild@0.21.5": true,
    "sharp@0.32.6": true,
    "tree-sitter@0.22.4": true
  }
}
