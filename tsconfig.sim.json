{
  "compilerOptions": {
    "outDir": "dist/sim",
    "rootDir": "src",
    "module": "commonjs",
    "target": "es2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "strict": false,
    "noImplicitAny": false
  },
  "include": [
    "src/main/sim/**/*.ts",
    "src/main/rag/worldbook.ts"
  ]
}